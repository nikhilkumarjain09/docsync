{
  "name": "docsync-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,relay -c blue,green \"pnpm --filter web dev\" \"pnpm --filter ws-relay dev\"",
    "dev:db": "docker compose up -d",
    "dev:all": "pnpm dev:db && pnpm dev",
    "build": "pnpm --filter web build && pnpm --filter ws-relay build",
    "lint": "pnpm --filter web lint && pnpm --filter ws-relay lint",
    "test": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "overrides": {
    "yjs": "^13.6.31",
    "y-prosemirror": "^1.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
