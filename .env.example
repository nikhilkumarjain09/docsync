# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/docsync

# ─── Auth.js (NextAuth v5) ──────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# ─── AI Providers ───────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# ─── WebSocket Relay ────────────────────────────────────────────
# URL of the standalone WS relay server (separate deployment)
WS_RELAY_URL=ws://localhost:4444

# ─── Email Configuration (SMTP Fallback / Gmail) ─────────────────
# Add these variables to switch to Gmail SMTP instead of Resend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="DocSync <your-email@gmail.com>"

