# ─── Database ────────────────────────────────────────────────────
# Must match apps/web/.env exactly
DATABASE_URL=postgresql://user:password@localhost:5432/docsync

# ─── Auth ────────────────────────────────────────────────────────
# Must match apps/web/.env exactly to allow JWT handshake verification
AUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Server Configuration ────────────────────────────────────────
PORT=4444
HOST=0.0.0.0
