datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model User {
  id             String                 @id @default(cuid())
  email          String                 @unique
  emailVerified  DateTime?
  name           String?
  hashedPassword String?
  image          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  collaborations DocumentCollaborator[]
  ownedDocuments Document[]             @relation("DocumentOwner")
  updatesCreated DocumentUpdateLog[]    @relation("UpdateCreator")
  snapshots      DocumentSnapshot[]     @relation("SnapshotCreator")
  favorites      FavoriteDocument[]
}

model Document {
  id              String                 @id @default(cuid())
  title           String
  ownerId         String
  owner           User                   @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  latestSnapshot  Bytes? // Y.encodeStateAsUpdate bytea checkpoint
  snapshotVersion Int                    @default(0)
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  collaborators   DocumentCollaborator[]
  updateLogs      DocumentUpdateLog[]
  snapshots       DocumentSnapshot[]
  favoritedBy     FavoriteDocument[]
}

model DocumentCollaborator {
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([documentId, userId])
}

model DocumentUpdateLog {
  id                     String   @id @default(cuid())
  documentId             String
  document               Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  update                 Bytes // The Yjs state update bytea
  createdBy              String
  creator                User     @relation("UpdateCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  restoredFromSnapshotId String?
  createdAt              DateTime @default(now())

  @@index([documentId])
}

model DocumentSnapshot {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  state      Bytes // Y.encodeStateAsUpdate checkpoint bytea
  createdBy  String
  creator    User     @relation("SnapshotCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  label      String?
  createdAt  DateTime @default(now())

  @@index([documentId])
}

model FavoriteDocument {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, documentId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}
