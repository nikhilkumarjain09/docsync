datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  title     String
  content   Bytes? // Y.encodeStateAsUpdate checkpoint
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
